# Main background, empty for terminal default, need to be empty if you want transparent background
theme[main_bg]="#18120c"

# Main text color
theme[main_fg]="#eee0d4"

# Title color for boxes
theme[title]="#f7bb70"

# Highlight color for keyboard shortcuts
theme[hi_fg]="#dfc2a2"

# Background color of selected items
theme[selected_bg]="#3b332b"

# Foreground color of selected items
theme[selected_fg]="#f7bb70"

# Color of inactive/disabled text
theme[inactive_fg]="#9c8e80"  

# Color of text appearing on top of graphs, i.e uptime and current network graph scaling
theme[graph_text]="#d4c4b5"

# Misc colors for processes box including mini cpu graphs, details memory graph and details status text
theme[proc_misc]="#bacd9f"

# Box outline colors
theme[cpu_box]="#504539"
theme[mem_box]="#504539"
theme[net_box]="#504539"
theme[proc_box]="#504539"
theme[div_line]="#504539"

# Temperature graph colors (Primary -> Tertiary -> Error)
theme[temp_start]="#f7bb70"
theme[temp_mid]="#bacd9f"
theme[temp_end]="#ffb4ab"

# CPU graph colors
theme[cpu_start]="#f7bb70"
theme[cpu_mid]="#bacd9f"
theme[cpu_end]="#ffb4ab"

# Mem/Disk free meter (Reversed: Error -> Tertiary -> Primary)
theme[free_start]="#ffb4ab"
theme[free_mid]="#bacd9f"
theme[free_end]="#f7bb70"

# Mem/Disk cached meter
theme[cached_start]="#dfc2a2"
theme[cached_mid]="#57432b"
theme[cached_end]="#f7bb70"

# Mem/Disk available meter
theme[available_start]="#ffb4ab"
theme[available_mid]="#bacd9f"
theme[available_end]="#f7bb70"

# Mem/Disk used meter
theme[used_start]="#f7bb70"
theme[used_mid]="#bacd9f"
theme[used_end]="#ffb4ab"

# Download graph colors
theme[download_start]="#f7bb70"
theme[download_mid]="#dfc2a2"
theme[download_end]="#bacd9f"

# Upload graph colors
theme[upload_start]="#bacd9f"
theme[upload_mid]="#dfc2a2"
theme[upload_end]="#f7bb70"

# Process box color gradient for threads, mem and cpu usage
theme[process_start]="#f7bb70"
theme[process_mid]="#bacd9f"
theme[process_end]="#ffb4ab"
