{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",

    "logo": {
        "source": "$HOME/.config/fastfetch/ascii.txt",
        "color": {
            "1": "#f7bb70",
            "2": "#dfc2a2"
        },
        "padding": {
            "top": 4,
            "left": 3
        }
    },

    "display": {
        "separator": " ",
        "bar": {
            "char": {
                "elapsed": "■",
                "total": "□"
            },
            "width": 13
        },
        "percent": {
            "type": 2
        }
    },

    "modules": [
        "break",

        {
            "type": "custom",
            "format": "\u001b[90m╭─────────────────────────────── System ───────────────────────────────"
        },
        {
            "type": "host",
            "key": "│  Host       ",
            "keyColor": "#f7bb70",
            "keyWidth": 16
        },
        {
            "type": "os",
            "key": "│ ├ OS       ",
            "keyColor": "#f7bb70",
            "keyWidth": 16
        },
        {
            "type": "kernel",
            "key": "│ ├ Kernel   ",
            "keyColor": "#f7bb70",
            "keyWidth": 16
        },
        {
            "type": "bios",
            "key": "│ ├ BIOS     ",
            "keyColor": "#f7bb70",
            "keyWidth": 16
        },
        {
            "type": "de",
            "key": "│ ├ DE       ",
            "keyColor": "#f7bb70",
            "keyWidth": 16
        },
        {
            "type": "wm",
            "key": "│ ├󱂬 WM       ",
            "keyColor": "#f7bb70",
            "keyWidth": 16
        },
        {
            "type": "wmtheme",
            "key": "│ └󰉼 Theme    ",
            "keyColor": "#f7bb70",
            "keyWidth": 16
        },
        {
            "type": "custom",
            "format": "\u001b[90m╰─────────────────────────────────────────────────────────────────────┘"
        },

        "break",

        {
            "type": "custom",
            "format": "\u001b[90m╭────────────────────────────── Hardware ─────────────────────────────┐"
        },
        {
            "type": "cpu",
            "key": "│  CPU      ",
            "keyColor": "#dfc2a2",
            "keyWidth": 16
        },
        {
            "type": "gpu",
            "key": "│ ├ GPU       ",
            "keyColor": "#dfc2a2",
            "keyWidth": 16
        },
        {
            "type": "memory",
            "key": "│ ├ Memory   ",
            "keyColor": "#dfc2a2",
            "keyWidth": 16
        },
        {
            "type": "disk",
            "key": "│ └ Disk     ",
            "keyColor": "#dfc2a2",
            "keyWidth": 16
        },
        {
            "type": "custom",
            "format": "\u001b[90m╰─────────────────────────────────────────────────────────────────────┘"
        },

        "break",

        {
            "type": "custom",
            "format": "\u001b[90m╭─────────────────────────────── Session ─────────────────────────────┐"
        },
        {
            "type": "shell",
            "key": "│  Shell    ",
            "keyColor": "#bacd9f",
            "keyWidth": 16
        },
        {
            "type": "terminal",
            "key": "│ ├ Terminal ",
            "keyColor": "#bacd9f",
            "keyWidth": 16
        },
        {
            "type": "packages",
            "key": "│ ├󰏖 Packages ",
            "keyColor": "#bacd9f",
            "keyWidth": 16
        },
        {
            "type": "command",
            "key": "│ ├󰩹 OS Age   ",
            "keyColor": "#bacd9f",
            "keyWidth": 16,
            "text": "birth_install=$(stat -c %W /); current=$(date +%s); time_progression=$((current - birth_install)); days_difference=$((time_progression / 86400)); echo $days_difference days"
        },
        {
            "type": "uptime",
            "key": "│ ├ Uptime   ",
            "keyColor": "#bacd9f",
            "keyWidth": 16
        },
        {
            "type": "datetime",
            "key": "│ └󰃰 DateTime ",
            "keyColor": "#bacd9f",
            "keyWidth": 16
        },
        {
            "type": "custom",
            "format": "\u001b[90m╰─────────────────────────────────────────────────────────────────────"
        },

        "break",

        {
            "type": "colors",
            "paddingLeft": 3,
            "symbol": "circle"
        }
    ]
}
